<div class="cursor-pointer p-4 bg-white flex flex-col rounded-sm border border-gray-300 hover:bg-gray-50">
  <div class="flex-grow">
    <div class="flex justify-between items-start mb-2">
      <div>
        <h3 class="text-lg font-semibold inline-block mr-2"><%= name %></h3>
        <span class="text-sm text-gray-500">1 serving</span>
      </div>
      <div class="text-right">
        <p class="text-xl font-bold text-gray-800">450 <span class="text-sm font-normal text-gray-500">kcal</span></p>
      </div>
    </div>
  </div>
  <div class="flex justify-between items-center text-sm text-gray-600 space-x-4">
    <div class="flex gap-x-2">
      <span>P: 25g</span>
      <span>F: 15g</span>
      <span>C: 50g</span>
    </div>
    <button class="text-xs text-red-500 hover:underline rounded-sm">Remove</button>
  </div>
</div>

