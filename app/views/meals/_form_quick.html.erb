<div class="p-4 bg-white rounded-sm border border-gray-300">
  <form class="flex flex-col gap-4">
    <div class="grid grid-cols-5 gap-4 items-end">
      <div class="col-span-3">
        <input type="text" id="new-food-name" name="new-food-name" placeholder="Start typing to search..." autocomplete="off" class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-sm sm:text-sm bg-white" />
      </div>
      <div class="col-span-2 mt-1 flex gap-x-0">
        <input type="number" id="new-quantity" name="new-quantity" min="0" step="0.1" placeholder="0" class="block w-full px-3 py-2 border border-gray-300 rounded-l-sm sm:text-sm bg-white" />
        <select id="new-unit" name="new-unit" class="block px-3 py-2 border border-gray-300 rounded-r-sm bg-white sm:text-sm">
          <option value="g">g</option>
          <option value="servings">servings</option>
        </select>
      </div>
    </div>
    <div class="flex space-x-2">
      <button type="submit" class="px-3 py-1 text-xs font-medium text-white bg-lime-600 hover:bg-lime-700 rounded-sm">Add</button>
      <button type="button" class="px-3 py-1 text-xs font-medium bg-gray-200 hover:bg-gray-300 rounded-sm">Cancel</button>
    </div>
  </form>
</div>
