<h1 class="p-4 text-xl font-bold bg-gray-200 sticky top-0 z-100">Pantry</h1>

<section class="flex flex-col p-4 gap-4 overflow-auto">
  <div class="flex items-stretch gap-4">
    <input type="search" name="product-search" placeholder="Search products..." class="min-w-10 flex-1 px-3 py-2 border border-gray-300 rounded-sm bg-white" />
    <button class="flex-none px-3 py-2 font-medium text-white bg-lime-600 hover:bg-lime-700 rounded-sm">Add product</button>
  </div>

  <%= render Current.user.products.order(:name) %>

  <form class="p-2 flex flex-col gap-y-2 border border-gray-300 rounded-sm bg-white text-sm">
    <div class="flex flex-wrap gap-2">
      <input type="text" value="Banana" placeholder="Product Name" class="min-w-30 flex-1 border border-gray-300 rounded-sm bg-white" />
      <div class="flex">
        <input type="number" value="105" placeholder="Calories" class="border border-gray-300 rounded-l-sm bg-white w-20" />
        <span class="input-addon">kcal/100g</span>
      </div>
    </div>

    <div class="flex flex-wrap gap-2">
      <div class="flex flex-1 min-w-40">
        <input type="number" step="0.1" value="1.3" placeholder="Protein" class="min-w-10 flex-1 border border-gray-300 rounded-l-sm bg-white" />
        <span class="input-addon">protein</span>
      </div>
      <div class="flex flex-1 min-w-40">
        <input type="number" step="0.1" value="0.4" placeholder="Fat" class="min-w-10 flex-1 border border-gray-300 rounded-l-sm bg-white" />
        <span class="input-addon">fat</span>
      </div>
      <div class="flex flex-1 min-w-40">
        <input type="number" step="0.1" value="27.0" placeholder="Carbs" class="min-w-10 flex-1 border border-gray-300 rounded-l-sm bg-white" />
        <span class="input-addon">carbs</span>
      </div>
    </div>

    <div class="flex flex-wrap gap-2 items-baseline">
      Portion:
      <select name="portion-type-banana" class="border border-gray-300 rounded-sm bg-white">
        <option value="" disabled selected>-</option>
        <option>spoon</option>
        <option>cup</option>
      </select>
      =
      <div class="flex min-w-40">
        <input type="number" name="portion-size-banana" value="" placeholder="size" class="min-w-10 border border-gray-300 rounded-l-sm bg-white" />
        <span class="input-addon">g</span>
      </div>
    </div>

    <div class="flex gap-2">
      <button type="submit" aria-label="Save Banana" class="px-3 py-1 font-medium text-white bg-lime-600 hover:bg-lime-700 rounded-sm">Save</button>
      <button type="button" aria-label="Cancel edit Banana" class="px-3 py-1 font-medium text-gray-700 bg-gray-200 hover:bg-gray-300 rounded-sm">Cancel</button>
    </div>
  </form>
</section>
