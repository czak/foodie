<div class="flex items-center px-4 py-2 bg-gray-200 sticky top-0 z-100 gap-4">
  <h1 class="flex-1 text-xl font-bold">Pantry</h1>
  <%= link_to "Add product", new_product_path, class: "px-3 py-2 font-medium text-sm text-white bg-lime-600 hover:bg-lime-700 rounded-sm", data: { action: "page#showForm" } %>
</div>

<section class="flex flex-col p-4 gap-4 overflow-auto">
  <%= form_with url: products_path, method: :get, class: "flex items-stretch bg-white border border-gray-300 rounded-sm" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Search products", class: "w-full px-3 py-2", autocomplete: "off" %>
    <div class="flex items-center">
      <%= link_to "close", products_path, title: "Reset search", class: "material-icon text-gray-400 hover:text-gray-700 px-2 py-1" %>
    </div>
  <% end %>

  <div class="hidden" data-page-target="form">
    <%= render "form", product: Product.new %>
  </div>

  <%= render @products %>
</section>
